msgid "Поиск по названию, теме..."
msgstr "Атауы, тақырыбы бойынша іздеу..."

msgid "Добавить"
msgstr "Қосу"

msgid "Выйти"
msgstr "Шығу"

msgid "Войти"
msgstr "Кіру"

msgid "Регистрация"
msgstr "Тіркелу"

msgid "Навигация"
msgstr "Навигация"

msgid "Все материалы"
msgstr "Барлық материалдар"

msgid "Категории"
msgstr "Санаттар"

msgid "Предметы"
msgstr "Пәндер"

msgid "Результаты поиска"
msgstr "Іздеу нәтижелері"

msgid "Сбросить фильтр"
msgstr "Сүзгіні тазалау"

msgid "Материалы не найдены"
msgstr "Материалдар табылмады"

msgid "Попробуйте изменить запрос или"
msgstr "Сұрауды өзгертіп көріңіз немесе"

msgid "сбросить фильтры"
msgstr "сүзгілерді тазалау"

msgid "Станьте первым, кто поделится знаниями!"
msgstr "Білімді бөлісетін бірінші болыңыз!"

msgid "+ Добавить материал"
msgstr "+ Материал қосу"

msgid "Удалить этот материал?"
msgstr "Бұл материалды жою керек пе?"

msgid "Открыть"
msgstr "Ашу"

msgid "Комментарии"
msgstr "Пікірлер"

msgid "Комментариев пока нет. Будьте первым!"
msgstr "Әлі пікір жоқ. Бірінші болыңыз!"

msgid "Добавить комментарий..."
msgstr "Пікір қосу..."

msgid "Войдите"
msgstr "Кіріңіз"

msgid "чтобы оставить комментарий"
msgstr "пікір қалдыру үшін"

msgid "Участник с"
msgstr "Мүше болғалы"

msgid "материалов загружено"
msgstr "материал жүктелген"

msgid "Публикации"
msgstr "Жарияланымдар"

msgid "Материалов пока нет"
msgstr "Материалдар әлі жоқ"

msgid "Поделитесь чем-нибудь полезным!"
msgstr "Пайдалы нәрсемен бөлісіңіз!"

msgid "Изменить фото"
msgstr "Фотосуретті өзгерту"

msgid "Добро пожаловать"
msgstr "Қош келдіңіз"

msgid "Войдите в свой аккаунт"
msgstr "Есептік жазбаңызға кіріңіз"

msgid "Пароль"
msgstr "Құпия сөз"

msgid "Запомнить меня"
msgstr "Мені есте сақта"

msgid "Нет аккаунта?"
msgstr "Есептік жазбаңыз жоқ па?"

msgid "Зарегистрироваться"
msgstr "Тіркелу"

msgid "Создать аккаунт"
msgstr "Есептік жазба жасау"

msgid "Присоединяйтесь к библиотеке знаний"
msgstr "Білім кітапханасына қосылыңыз"

msgid "Минимум 6 символов"
msgstr "Кемінде 6 таңба"

msgid "Подтвердите пароль"
msgstr "Құпия сөзді растаңыз"

msgid "Повторите пароль"
msgstr "Құпия сөзді қайталаңыз"

msgid "Уже есть аккаунт?"
msgstr "Есептік жазбаңыз бар ма?"

msgid "Назад"
msgstr "Артқа"

msgid "Добавить материал"
msgstr "Материал қосу"

msgid "Поделитесь полезным ресурсом с командой"
msgstr "Пайдалы ресурспен командамен бөлісіңіз"

msgid "Название"
msgstr "Атауы"

msgid "Например: Лекция по алгоритмам — MIT OpenCourseWare"
msgstr "Мысалы: MIT — алгоритмдер бойынша дәріс"

msgid "Ссылка"
msgstr "Сілтеме"

msgid "Категория"
msgstr "Санат"

msgid "Предмет / Тема"
msgstr "Пән / Тақырып"

msgid "Описание"
msgstr "Сипаттама"

msgid "Кратко опишите, чем полезен этот материал..."
msgstr "Бұл материалдың пайдасын қысқаша сипаттаңыз..."

msgid "Отмена"
msgstr "Болдырмау"

msgid "Опубликовать"
msgstr "Жариялау"

msgid "Заполните все обязательные поля."
msgstr "Барлық міндетті өрістерді толтырыңыз."

msgid "Материал успешно добавлен!"
msgstr "Материал сәтті қосылды!"

msgid "Материал удалён."
msgstr "Материал жойылды."

msgid "Комментарий не может быть пустым."
msgstr "Пікір бос болуы мүмкін емес."

msgid "Пожалуйста, войдите в систему."
msgstr "Жүйеге кіріңіз."

msgid "Неверное имя пользователя или пароль."
msgstr "Пайдаланушы аты немесе құпия сөз дұрыс емес."

msgid "Это имя пользователя уже занято."
msgstr "Бұл пайдаланушы аты бос емес."

msgid "Имя пользователя должно содержать минимум 3 символа."
msgstr "Пайдаланушы аты кемінде 3 таңбадан тұруы керек."

msgid "Пароль должен содержать минимум 6 символов."
msgstr "Құпия сөз кемінде 6 таңбадан тұруы керек."

msgid "Добро пожаловать, %(username)s!"
msgstr "Қош келдіңіз, %(username)s!"

msgid "Файл не выбран."
msgstr "Файл таңдалмаған."

msgid "Недопустимый формат файла. Используйте JPG, PNG, GIF или WebP."
msgstr "Файл форматы жарамсыз. JPG, PNG, GIF немесе WebP пайдаланыңыз."

msgid "Фото профиля обновлено!"
msgstr "Профиль суреті жаңартылды!"

msgid "Лекция"
msgstr "Дәріс"

msgid "Книга"
msgstr "Кітап"

msgid "Статья"
msgstr "Мақала"

msgid "Видео"
msgstr "Бейне"

msgid "Задание"
msgstr "Тапсырма"

msgid "Другое"
msgstr "Басқа"
